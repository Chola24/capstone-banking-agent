# =============================================================================
# Secrets & environment — NEVER commit these
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Python virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# Python compiled artifacts
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# =============================================================================
# Notebook checkpoints
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
# Vector store — REGENERABLE from ingest.py, so don't bloat git history
# (We rebuild it from data/raw/ anytime.)
# =============================================================================
vectorstore/

# =============================================================================
# IDEs & editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Logs (keep curated samples though)
# =============================================================================
