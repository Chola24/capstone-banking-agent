# =============================================================================
# Environment configuration — copy this file to .env and fill in your secrets.
# .env is gitignored, so it never gets committed.
# =============================================================================

# --- OpenAI API key (REQUIRED) ---------------------------------------------
# Local dev: get a key from https://platform.openai.com/api-keys
# Vocareum:  use the key shown in the GenAI Details panel inside Vocareum
OPENAI_API_KEY=sk-your-openai-key-here

# --- Optional: API base override -------------------------------------------
# Leave commented for local dev (uses OpenAI's default endpoint).
# Uncomment and set when running inside Vocareum:
# OPENAI_API_BASE=https://openai.vocareum.com/v1

# --- Model selection -------------------------------------------------------
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Chunking parameters ---------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval parameters --------------------------------------------------
TOP_K=4
